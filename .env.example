# WalletConnect Project ID (optional - demo mode works without it)
# Get one from: https://cloud.walletconnect.com/
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# 0G Network Configuration (server-side — inference)
OG_RPC_URL=https://evmrpc-testnet.0g.ai
OG_ROUTER_API=https://router-api.0g.ai/v1

# 0G Network Configuration (client-side — storage uploads signed by user wallet)
NEXT_PUBLIC_OG_RPC_URL=https://evmrpc-testnet.0g.ai
NEXT_PUBLIC_OG_STORAGE_INDEXER=https://indexer-storage-testnet-turbo.0g.ai

# WorkflowRegistry contract addresses — fill after deploy
# npx hardhat run scripts/deploy-registry.cjs --network og0testnet
NEXT_PUBLIC_REGISTRY_ADDRESS_16602=

# npx hardhat run scripts/deploy-registry.cjs --network og0mainnet
NEXT_PUBLIC_REGISTRY_ADDRESS_16661=

# Deployer private key — used by hardhat deploy scripts only, never exposed to browser
PRIVATE_KEY=0x...
